// Append these models to apps/*/prisma/schema.prisma (below datasource), then run prisma migrate.

model Lead {
  id        String   @id @default(cuid())
  email     String?
  name      String?
  company   String?
  status    String   @default("new")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
