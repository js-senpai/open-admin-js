NODE_ENV=development
DATABASE_URL=postgresql://openadminjs:openadminjs@localhost:5432/openadminjs?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-too
ADMIN_ORIGIN=http://localhost:3000
API_PORT=4000
# Optional: OIDC / OAuth2 SSO (Authorization Code + PKCE).
# You can either set OIDC_ISSUER directly, or use OIDC_PROVIDER preset (google|microsoft|auth0|okta).
# OIDC_REDIRECT_URI must EXACTLY match the callback host + path seen by the API and the IdP app registration.
# OIDC_ISSUER=https://your-idp.example.com/realms/your-realm
# OIDC_PROVIDER=google
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:4000/auth/sso/oidc/callback
# OIDC_SCOPES=openid email profile
# New users get this admin realm role if it exists (default: viewer).
# OIDC_DEFAULT_ROLE=viewer
# Stricter per-user bucket (valid JWT sub); in addition to default IP throttler.
# RATE_LIMIT_USER_PER_MIN=120

# Admin app: show "Continue with SSO" when API has OIDC_* set
# NEXT_PUBLIC_OIDC_LOGIN=true
