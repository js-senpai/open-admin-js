{
  "name": "__PACKAGE_NAME__",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @openadminjs/api --filter @openadminjs/admin dev",
    "build": "pnpm -r build",
    "start": "pnpm --parallel --filter @openadminjs/api --filter @openadminjs/admin start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @openadminjs/api db:migrate",
    "db:seed": "pnpm --filter @openadminjs/api db:seed",
    "db:studio": "pnpm --filter @openadminjs/api db:studio",
    "generate": "pnpm --filter @openadminjs/api generate"
  },
  "devDependencies": {
    "@prisma/client": "^6.1.0",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "overrides": {
      "@nestjs/apollo": "13.4.0",
      "@nestjs/common": "11.1.21",
      "@nestjs/config": "4.0.4",
      "@nestjs/core": "11.1.21",
      "@nestjs/graphql": "13.4.0",
      "@nestjs/jwt": "11.0.2",
      "@nestjs/platform-express": "11.1.21",
      "@nestjs/swagger": "11.4.3",
      "@nestjs/throttler": "6.5.0",
      "class-transformer": "0.5.1",
      "class-validator": "0.14.4",
      "reflect-metadata": "0.2.2",
      "rxjs": "7.8.2"
    }
  }
}
