{
  "name": "openadminjs",
  "version": "0.1.25",
  "description": "CLI scaffold generator for OpenAdminJS monorepos (NestJS, Prisma, Next.js). Not a runtime library — use npx openadminjs create.",
  "license": "MIT",
  "keywords": [
    "openadminjs",
    "admin",
    "nestjs",
    "nextjs",
    "prisma",
    "cli",
    "scaffold",
    "generator",
    "monorepo"
  ],
  "homepage": "https://js-senpai.github.io/open-admin-js/",
  "bugs": {
    "url": "https://github.com/js-senpai/open-admin-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/js-senpai/open-admin-js.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "openadminjs": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./create-project": {
      "types": "./dist/create-project.d.ts",
      "default": "./dist/create-project.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "template",
    "README.md"
  ],
  "scripts": {
    "sync-template": "node ../../scripts/sync-template.mjs",
    "prepack": "pnpm run build",
    "build": "node ../../scripts/sync-template.mjs && tsc -p tsconfig.json && node ../../scripts/make-executable.mjs dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run sync-template && vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "cac": "^6.7.14",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "typescript": "^5.7.2",
    "vitest": "^3.2.0"
  }
}
