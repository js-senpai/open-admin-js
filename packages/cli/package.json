{
  "name": "openadminjs",
  "version": "0.1.7",
  "type": "module",
  "bin": {
    "openadminjs": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./create-project": {
      "types": "./dist/create-project.d.ts",
      "default": "./dist/create-project.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "template",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/make-executable.mjs dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "cac": "^6.7.14",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
