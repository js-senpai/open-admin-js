{
  "name": "openadminjs",
  "version": "0.1.5",
  "description": "Resource-driven admin platform for Node.js teams.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @openadminjs/api --filter @openadminjs/admin dev",
    "site:check": "node scripts/check-static-site.mjs",
    "build": "pnpm -r build",
    "start": "pnpm --parallel --filter @openadminjs/api --filter @openadminjs/admin start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @openadminjs/resource build && pnpm -r test",
    "e2e": "pnpm --filter @openadminjs/admin exec vitest run lib/auth-flow.e2e.test.ts && node scripts/e2e-smoke.mjs",
    "doctor": "node packages/cli/dist/index.js doctor",
    "security:check": "node packages/cli/dist/index.js security check",
    "db:migrate": "pnpm --filter @openadminjs/api db:migrate",
    "db:seed": "pnpm --filter @openadminjs/api db:seed",
    "brand:assets": "node packages/brand/src/generate-assets.mjs"
  },
  "devDependencies": {
    "@prisma/client": "^6.1.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "openadminjs": "workspace:*",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "tmp@<=0.2.3": ">=0.2.4",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "lodash@<=4.17.23": ">=4.17.23",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "@apollo/server@<5.5.0": ">=5.5.0",
      "webpack@>=5.49.0 <5.104.1": ">=5.104.1",
      "multer@<2.1.1": ">=2.1.1",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "file-type@>=13.0.0 <21.3.2": ">=21.3.2",
      "nodemailer": "^8.0.5",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "vite": "^6.4.2",
      "postcss@<8.5.10": ">=8.5.10",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "next@>=12.2.0 <15.5.18": ">=15.5.18",
      "@nestjs/apollo": "13.4.0",
      "@nestjs/common": "11.1.21",
      "@nestjs/config": "4.0.4",
      "@nestjs/core": "11.1.21",
      "@nestjs/graphql": "13.4.0",
      "@nestjs/jwt": "11.0.2",
      "@nestjs/platform-express": "11.1.21",
      "@nestjs/swagger": "11.4.3",
      "@nestjs/throttler": "6.5.0",
      "class-transformer": "0.5.1",
      "class-validator": "0.14.4",
      "reflect-metadata": "0.2.2",
      "rxjs": "7.8.2"
    }
  }
}
