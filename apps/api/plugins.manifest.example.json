{
  "version": 1,
  "plugins": [
    {
      "id": "io.openadminjs.hello",
      "enabled": true,
      "trustMode": "trusted",
      "capabilities": ["resource.hooks"],
      "bundled": "hello",
      "config": { "tag": "optional-config-passed-to-plugin" }
    },
    {
      "id": "io.openadminjs.seo",
      "enabled": false,
      "trustMode": "sandboxed",
      "capabilities": ["seo.extend"],
      "bundled": "seo",
      "config": {}
    },
    {
      "id": "io.openadminjs.webhook",
      "enabled": false,
      "trustMode": "sandboxed",
      "capabilities": ["resource.hooks"],
      "bundled": "webhook",
      "config": {
        "url": "https://example.com/openadmin-hooks",
        "secret": "optional-shared-secret",
        "resources": ["posts", "orders"]
      }
    },
    {
      "id": "com.vendor.billing",
      "enabled": false,
      "trustMode": "sandboxed",
      "capabilities": ["resource.hooks", "api.routes", "jobs.run", "admin.ui.extend"],
      "package": "@vendor/openadmin-billing",
      "marketplace": {
        "listingUrl": "https://example.com/plugins/billing",
        "productId": "sku-123",
        "licenseKey": "signing-key-or-token-for-future-use"
      },
      "config": { "currency": "EUR" }
    }
  ]
}
