{
  "name": "@openadminjs/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "nest build",
    "start": "node dist/apps/api/src/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "db:seed": "prisma db seed --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@casl/ability": "^6.8.1",
    "@nestjs/apollo": "^12.2.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/graphql": "^12.2.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.3.0",
    "@openadminjs/core": "workspace:*",
    "@openadminjs/mail": "workspace:*",
    "@openadminjs/payments": "workspace:*",
    "@openadminjs/permissions": "workspace:*",
    "@openadminjs/plugin-sdk": "workspace:*",
    "@openadminjs/storage": "workspace:^",
    "@prisma/client": "^6.1.0",
    "@types/express": "^5.0.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "graphql": "^16.14.0",
    "graphql-scalars": "^1.25.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^6.9.16",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^17.7.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^6.1.0",
    "tsx": "4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx ../../prisma/seed.ts"
  }
}
